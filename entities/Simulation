{
  "name": "Simulation",
  "type": "object",
  "properties": {
    "scenario_id": {
      "type": "string",
      "description": "ID do cen\u00e1rio utilizado"
    },
    "agent_name": {
      "type": "string",
      "description": "Nome do agente em treinamento"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sender": {
            "type": "string",
            "enum": [
              "agent",
              "client"
            ]
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      },
      "description": "Hist\u00f3rico de mensagens da simula\u00e7\u00e3o"
    },
    "duration_minutes": {
      "type": "number",
      "description": "Dura\u00e7\u00e3o da simula\u00e7\u00e3o em minutos"
    },
    "status": {
      "type": "string",
      "enum": [
        "em_andamento",
        "concluida",
        "abandonada"
      ],
      "default": "em_andamento",
      "description": "Status da simula\u00e7\u00e3o"
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "overall_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "empathy_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "resolution_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "professionalism_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "agility_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "feedback": {
          "type": "string"
        },
        "strengths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "improvements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "scenario_id",
    "agent_name"
  ]
}